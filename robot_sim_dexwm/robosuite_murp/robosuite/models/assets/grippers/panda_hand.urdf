<mujoco model="panda_hand">
  <compiler angle="radian"/>

  <asset>
    <mesh name="hand" file="meshes/panda_gripper/hand.stl"/>
    <mesh name="hand_vis" file="meshes/panda_gripper/hand_vis.stl"/>
    <mesh name="finger" file="meshes/panda_gripper/finger.stl"/>
    <mesh name="finger_vis" file="meshes/panda_gripper/finger_vis.stl"/>
    <mesh name="finger_vis2" file="meshes/panda_gripper/finger_longer.stl"/>
  </asset>

  <worldbody>
    <body name="right_gripper" quat="0.707107 0 0 -0.707107">
      <inertial pos="0 0 0.17" quat="0.707107 0.707107 0 0" mass="0.3" diaginertia="0.09 0.07 0.05"/>
      <geom name="hand_visual" quat="0.707107 0 0 0.707107" type="mesh" contype="0" conaffinity="0" group="1" rgba="1 1 1 1" mesh="hand_vis"/>
      <geom name="hand_collision" quat="0.707107 0 0 0.707107" type="mesh" mesh="hand"/>
      <site name="ft_frame" pos="0 0 0" size="0.01" group="1" rgba="1 0 0 1"/>
      <body name="eef" pos="0 0 0.097">
        <site name="grip_site" pos="0 0 0" size="0.01" group="1" rgba="1 0 0 0.5"/>
        <site name="ee_x" pos="0.1 0 0" quat="0.707105 0 0.707108 0" size="0.005 0.1" group="1" type="cylinder" rgba="1 0 0 0"/>
        <site name="ee_y" pos="0 0.1 0" quat="0.707105 0.707108 0 0" size="0.005 0.1" group="1" type="cylinder" rgba="0 1 0 0"/>
        <site name="ee_z" pos="0 0 0.1" size="0.005 0.1" group="1" type="cylinder" rgba="0 0 1 0"/>
        <site name="grip_site_cylinder" pos="0 0 0" size="0.005 10" group="1" type="cylinder" rgba="0 1 0 0.3"/>
      </body>
      <body name="leftfinger" pos="0 0 0.0524" quat="0.707107 0 0 0.707107">
        <inertial pos="0 0 0.05" mass="0.1" diaginertia="0.01 0.01 0.005"/>
        <joint name="finger_joint1" pos="0 0 0" axis="0 1 0" type="slide" limited="true" range="0 0.04" armature="1" damping="100" frictionloss="1"/>
        <geom name="finger1_visual" type="mesh" contype="0" conaffinity="0" group="1" rgba="0.499 0.499 0.499 1" mesh="finger_vis"/>
        <geom name="finger1_collision" type="mesh" contype="0" condim="4" mesh="finger"/>
        <body name="finger_joint1_tip" pos="0 0.0085 0.056">
          <inertial pos="0 0 0" quat="0 0 0 1" mass="0.01" diaginertia="0.01 0.01 0.01"/>
          <geom name="finger1_pad_collision" size="0.008 0.004 0.008" pos="0 -0.005 -0.015" quat="0 0 0 1" type="box" friction="2 0.05" solref="0.01 0.5"/>
        </body>
      </body>
      <body name="rightfinger" pos="0 0 0.0524" quat="0.707107 0 0 0.707107">
        <inertial pos="0 0 0.05" mass="0.1" diaginertia="0.01 0.01 0.005"/>
        <joint name="finger_joint2" pos="0 0 0" axis="0 1 0" type="slide" limited="true" range="-0.04 0" armature="1" damping="100" frictionloss="1"/>
        <geom name="finger2_visual" quat="0 0 0 1" type="mesh" contype="0" conaffinity="0" group="1" rgba="0.499 0.499 0.499 1" mesh="finger_vis"/>
        <geom name="finger2_collision" quat="0 0 0 1" type="mesh" contype="0" condim="4" mesh="finger"/>
        <body name="finger_joint2_tip" pos="0 -0.0085 0.056">
          <inertial pos="0 0 0" quat="0 0 0 1" mass="0.01" diaginertia="0.01 0.01 0.01"/>
          <geom name="finger2_pad_collision" size="0.008 0.004 0.008" pos="0 0.005 -0.015" quat="0 0 0 1" type="box" friction="2 0.05" solref="0.01 0.5"/>
        </body>
      </body>
    </body>
  </worldbody>

  <actuator>
    <general name="gripper_finger_joint1" joint="finger_joint1" ctrllimited="true" ctrlrange="0 0.04" forcelimited="true" forcerange="-20 20" biastype="affine" gainprm="1000" biasprm="0 -1000"/>
    <general name="gripper_finger_joint2" joint="finger_joint2" ctrllimited="true" ctrlrange="-0.04 0" forcelimited="true" forcerange="-20 20" biastype="affine" gainprm="1000" biasprm="0 -1000"/>
  </actuator>

  <sensor>
    <force site="ft_frame" name="force_ee"/>
    <torque site="ft_frame" name="torque_ee"/>
  </sensor>
</mujoco>
